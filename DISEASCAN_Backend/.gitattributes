# ── Git LFS ───────────────────────────────────────────────────────────────────
# Track large model files via Git Large File Storage.
# Install LFS first:  git lfs install
# Then:                git lfs track "*.keras"
# ──────────────────────────────────────────────────────────────────────────────
*.keras filter=lfs diff=lfs merge=lfs -text
